  "isFree": true,
  "courses": [
    {
      "id": "rusd-01",
      "order": 1,
      "title": "早上起床",
      "description": "早晨起床后常用对话。",
      "statements": [
        {
          "english": "До́брое у́тро! Пора́ встава́ть.",
          "chinese": "早上好！该起床了。",
          "soundmark": "DOB-ra-ye OOT-ra pa-RA vsta-VAT"
        },
        {
          "english": "Кото́рый час?",
          "chinese": "几点了？",
          "soundmark": "ka-TO-ry chas"
        },
        {
          "english": "Я проспа́л(а)!",
          "chinese": "我睡过头了！",
          "soundmark": "ya pras-PAL(a)"
        },
        {
          "english": "Ну́жно чи́стить зу́бы.",
          "chinese": "要刷牙。",
          "soundmark": "NOOZH-na CHEEST-eet ZOO-by"
        },
        {
          "english": "Что у нас на за́втрак?",
          "chinese": "早餐吃什么？",
          "soundmark": "shto oo nas na ZAV-trak"
        }
      ]
    },
    {
      "id": "rusd-02",
      "order": 2,
      "title": "晚间休息",
      "description": "晚上回家和就寝前常用表达。",
      "statements": [
        {
          "english": "Я верну́лся(ась) домо́й.",
          "chinese": "我回家了。",
          "soundmark": "ya ver-NOOL-sya(s) da-MOY"
        },
        {
          "english": "Да, я о́чень уста́л(а).",
          "chinese": "是的，我很累。",
          "soundmark": "da ya O-chen oo-STAL(a)"
        },
        {
          "english": "Хо́чешь посмотре́ть фильм?",
          "chinese": "想看个电影吗？",
          "soundmark": "KHO-chesh pa-sma-TRYET feelm"
        },
        {
          "english": "Споко́йной но́чи!",
          "chinese": "晚安！",
          "soundmark": "spa-KOY-noy NO-chee"
        }
      ]
    },
    {
      "id": "rusd-03",
      "order": 3,
      "title": "穿衣打扮",
      "description": "早上穿衣打扮时的常用表达。",
      "statements": [
        {
          "english": "Что мне сего́дня наде́ть?",
          "chinese": "我今天穿什么？",
          "soundmark": "shto mne se-VOD-nya na-DYET"
        },
        {
          "english": "Э́та руба́шка мне идёт?",
          "chinese": "这件衬衫适合我吗？",
          "soundmark": "E-ta roo-BASH-ka mne ee-DYOT"
        },
        {
          "english": "Я наде́ну джи́нсы.",
          "chinese": "我穿牛仔裤。",
          "soundmark": "ya na-DE-noo DZHIN-sy"
        },
        {
          "english": "Где моя́ ку́ртка?",
          "chinese": "我的外套在哪？",
          "soundmark": "gde ma-YA KOORT-ka"
        },
        {
          "english": "Э́ти ту́фли мне жа́лмут.",
          "chinese": "这双鞋夹脚。",
          "soundmark": "E-tee TOOF-lee mne ZHMOOT"
        }
      ]
    },
    {
      "id": "rusd-04",
      "order": 4,
      "title": "早餐时间",
      "description": "吃早餐时的日常对话。",
      "statements": [
        {
          "english": "За́втрак гото́в!",
          "chinese": "早餐好了！",
          "soundmark": "ZAV-trak ga-TOF"
        },
        {
          "english": "На́лей мне чай, пожа́луйста.",
          "chinese": "请给我倒杯茶。",
          "soundmark": "NA-ley mne chay pa-ZHAL-sta"
        },
        {
          "english": "Ка́ша о́чень вку́сная.",
          "chinese": "粥很好吃。",
          "soundmark": "KA-sha O-chen VKOOS-na-ya"
        },
        {
          "english": "Вку́сный ко́фе!",
          "chinese": "咖啡好喝！",
          "soundmark": "VKOOS-ny KO-fye"
        },
        {
          "english": "Я не хочу́ есть у́тром.",
          "chinese": "我早上不想吃。",
          "soundmark": "ya ne kha-CHOO yest OOT-ram"
        }
      ]
    },
    {
