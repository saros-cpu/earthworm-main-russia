          "soundmark": "NA-da oo-BRA-tsa v KOM-na-tye"
        },
        {
          "english": "Пропылесо́сь, пожа́луйста.",
          "chinese": "请吸一下地。",
          "soundmark": "pra-py-le-SOS pa-ZHAL-sta"
        },
        {
          "english": "Вы́три пыль со стола́.",
          "chinese": "擦一下桌子上的灰。",
          "soundmark": "VY-tree pyl sa sta-LA"
        },
        {
          "english": "Помо́й посу́ду, пожа́луйста.",
          "chinese": "请洗碗。",
          "soundmark": "pa-MOY pa-SOO-doo pa-ZHAL-sta"
        }
      ]
    },
    {
