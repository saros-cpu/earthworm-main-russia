        {
          "english": "Включи́ му́зыку, пожа́луйста.",
          "chinese": "请放点音乐。",
          "soundmark": "vklyu-CHEE MOO-zy-koo pa-ZHAL-sta"
        }
      ]
    },
    {
      "id": "rusd-10",
