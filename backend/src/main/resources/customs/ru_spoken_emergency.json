  "courses": [
    {
      "id": "ruem-01",
      "order": 1,
      "title": "拨打急救电话",
      "description": "拨打112或103时的常用表达。",
      "statements": [
        {
          "english": "Звони́те по номе́ру 103!",
          "chinese": "请拨打103！",
          "soundmark": "zva-NEE-tye pa no-ME-roo sto-TREE"
        },
        {
          "english": "Ну́жен врач! Ско́ро!",
          "chinese": "需要医生！快！",
          "soundmark": "NOO-zhen vrach SKO-ra"
        },
        {
          "english": "Адре́с: у́лица Пушкина, дом 5.",
          "chinese": "地址是普希金大街5号。",
          "soundmark": "a-DRES OO-lee-tsa PUSH-kee-na dom pyat"
        },
        {
          "english": "Челове́к без созна́ния.",
          "chinese": "有人昏迷了。",
          "soundmark": "che-la-VYEk byez saz-NA-nee-ya"
        },
        {
          "english": "Пришли́те по́мощь, пожа́луйста!",
          "chinese": "请派人来帮忙！",
          "soundmark": "pri-SHLEE-tye PO-mashch pa-ZHAL-sta"
        }
      ]
    },
    {
