# JWT 密钥（必填）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# MySQL 数据库
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/earthworm?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&useUnicode=true
SPRING_DATASOURCE_USERNAME=reader
# 设置你的数据库密码
SPRING_DATASOURCE_PASSWORD=

# 仅在空库首次装载内置课程时临时改为 true；已有业务库保持 false
SEED_WRITE_ON_STARTUP=false

# 本地 HTTP 开发设为 false；HTTPS 部署必须改为 true
AUTH_SESSION_COOKIE_SECURE=false

# OpenRouter AI（可选）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Daily conservative output-token reservation cap for AI features
AI_DAILY_MAX_RESERVED_OUTPUT_TOKENS=100000
